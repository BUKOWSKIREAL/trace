{
  "name": "trace-electron",
  "version": "0.1.0",
  "description": "Trace Electron console for viewing local commit timelines and diffs.",
  "author": "bukowski",
  "main": "main.js",
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1",
    "start": "npm run build:renderer && electron .",
    "start:dev": "electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --mac --arm64",
    "build:all": "npm run build:renderer && electron-builder --mac --arm64 --x64",
    "build:win": "npm run build:renderer && electron-builder --win --x64"
  },
  "dependencies": {
    "sqlite3": "^6.0.1",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^7.2.4"
  },
  "build": {
    "appId": "cn.edu.shu.trace.electron",
    "productName": "Trace Console",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "dmg": {
      "title": "Trace Console",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer-dist/**/*",
      "icon.png",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
